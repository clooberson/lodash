{
  "name": "lodash",
  "version": "4.17.22",
  "description": "Lodash modular utilities.",
  "keywords": "modules, stdlib, util",
  "homepage": "https://lodash.com/",
  "repository": "lodash/lodash",
  "license": "MIT",
  "main": "lodash.js",
  "exports": {
    ".": {
      "require": "./lodash.js",
      "import": "./lodash.mjs",
      "default": "./lodash.js"
    }
  },
  "files": [
    "lodash.js",
    "lodash.min.js",
    "lodash.mjs",
    "lodash.fp.js",
    "fp",
    "core.js",
    "core.min.js"
  ],
  "scripts": {
    "test": "node test/test.js",
    "test:bun": "bun test/test.js",
    "test:fp": "node test/test-fp.js",
    "build": "node build/build.js",
    "lint": "eslint lodash.js",
    "docs": "node docs/build.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "qunit": "^2.21.1"
  },
  "engines": {
    "node": ">=12"
  }
}
